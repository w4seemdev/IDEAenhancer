# Claude API key for the /api/enhance proxy. When unset, the app falls back to a
# deterministic mock generator so both concepts stay fully demoable without keys.
ANTHROPIC_API_KEY=

# Optional model override. Defaults to claude-opus-4-8 (best idea quality).
# For a lower-cost free tier you could set claude-sonnet-4-6 or claude-haiku-4-5.
ANTHROPIC_MODEL=claude-opus-4-8
